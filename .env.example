# Copy to .env and adjust for your environment.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# Production backend
EXPO_PUBLIC_API_URL=https://motoxplus.com/api

# Local backend (Android emulator — 10.0.2.2 maps to host localhost)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# Local backend (iOS simulator — can use host localhost directly)
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Local backend (physical device — use your machine's LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000/api

EXPO_PUBLIC_RAZORPAY_KEY_ID=
